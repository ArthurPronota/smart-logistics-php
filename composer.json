{
  "name": "smart-logistics/notification-service",
  "description": "Сервис уведомлений на PHP",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "ext-sockets": "*",
    "laravel/framework": "^12.0",
    "php-amqplib/php-amqplib": "^3.7",
    "predis/predis": "^2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "SmartLogistics\\Notifications\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SmartLogistics\\Notifications\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "worker": "php artisan notifications:work"
  }
}
